<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Timetable | InfoCascade</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    body {
      background-color: #f8f9fa;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .timetable-section {
      background: #fff;
      border-radius: 14px;
      padding: 1.25rem;
      box-shadow: 0 10px 28px rgba(44, 62, 80, 0.08);
      margin-bottom: 2.5rem;
    }

    .department-switcher {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .department-chip {
      border: 1px solid #d0d7e2;
      background: #f5f8fb;
      color: #2c3e50;
      border-radius: 999px;
      padding: 0.45rem 0.85rem;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .department-chip.active,
    .department-chip:hover {
      border-color: #3498db;
      background: #3498db;
      color: #fff;
    }

    .department-group-label {
      background: linear-gradient(135deg, #3498db, #2c3e50);
      color: #fff;
      border-radius: 12px;
      padding: 0.75rem 1rem;
      font-weight: 600;
      margin-bottom: 1rem;
      position: sticky;
      top: 10px;
      z-index: 5;
    }

    .day-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 1rem;
    }

    .day-tab {
      border: 1px solid #d7dee8;
      background: #f8fafc;
      color: #2c3e50;
      border-radius: 8px;
      padding: 0.4rem 0.8rem;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .day-tab.active {
      background: #2c3e50;
      color: #fff;
      border-color: #2c3e50;
    }

    .period-card {
      border: 1px solid #ebeff5;
      border-radius: 10px;
      padding: 0.85rem;
      margin-bottom: 0.8rem;
      background: #fff;
    }

    .period-time {
      font-weight: 700;
      color: #2c3e50;
      min-width: 64px;
    }

    .type-badge {
      border-radius: 999px;
      padding: 0.2rem 0.55rem;
      font-size: 0.72rem;
      font-weight: 700;
      margin-right: 0.3rem;
      display: inline-block;
    }

    .type-lab {
      background: #e8f7ff;
      color: #0f6e9a;
    }

    .type-tut {
      background: #fff5dd;
      color: #875800;
    }

    .type-elective {
      background: #efe8ff;
      color: #4f2f8f;
    }

    .type-free {
      background: #edf2f7;
      color: #5c6775;
    }

    .period-entry {
      border-left: 3px solid #dbe4ef;
      padding-left: 0.65rem;
      margin-top: 0.5rem;
    }

    .period-entry.elective {
      border-left-color: #8d6be3;
      background: #faf7ff;
      padding: 0.5rem 0.65rem;
      border-radius: 8px;
    }

    @media (max-width: 768px) {
      .timetable-section {
        padding: 0.9rem;
      }

      .period-time {
        min-width: auto;
      }
    }
  </style>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/">InfoCascade</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNavbar">
        <div class="navbar-nav ms-auto text-center">
          <a class="nav-link" href="/">Home</a>
          <a class="nav-link active" href="/timetable">Timetable</a>
          <% if (!currentUser) { %>
            <a class="nav-link" href="/login">Login</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <section class="timetable-section" id="timetableSection">
      <h2 class="mb-3 text-center"><i class="fas fa-calendar-alt text-primary me-2"></i>Department Timetables</h2>
      <p class="text-muted text-center mb-3">Select a department, then switch days to view all periods in order.</p>
      <% if (currentUser && currentUser.department && currentUser.group) { %>
        <div class="alert alert-info mb-3">
          Showing your timetable for <strong><%= currentUser.department %></strong> • <strong><%= currentUser.group %></strong>.
        </div>
      <% } %>

      <div class="department-switcher" id="departmentSwitcher"></div>
      <div class="mb-3">
        <label class="form-label fw-semibold" for="groupSelector">Select Group</label>
        <select id="groupSelector" class="form-select" disabled>
          <option value="">Select department first</option>
        </select>
      </div>
      <div class="department-group-label" id="departmentGroupLabel">Department</div>
      <div class="day-tabs" id="dayTabs"></div>
      <div id="dayPeriodList"></div>
    </section>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const initialDepartmentOptions = <%- JSON.stringify((typeof departmentOptions !== 'undefined' && Array.isArray(departmentOptions)) ? departmentOptions : []) %>;
      const currentUser = <%- JSON.stringify(currentUser || null) %>;
      const userLockedTimetable = Boolean(currentUser && currentUser.department && currentUser.group);
      let departmentOptions = Array.isArray(initialDepartmentOptions) ? initialDepartmentOptions : [];
      const dayOrder = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

      const departmentSwitcher = document.getElementById('departmentSwitcher');
      const groupSelector = document.getElementById('groupSelector');
      const departmentGroupLabel = document.getElementById('departmentGroupLabel');
      const dayTabs = document.getElementById('dayTabs');
      const dayPeriodList = document.getElementById('dayPeriodList');

      let activeDepartmentKey = (currentUser && currentUser.department) || (departmentOptions[0] ? departmentOptions[0].key : null);
      let activeGroupName = '';
      let activeDepartmentData = null;
      let activeDay = 'Monday';

      function displayTypeBadges(period) {
        const badges = [];
        if (period.isFree) badges.push('<span class="type-badge type-free">FREE</span>');
        if (period.isLab) badges.push('<span class="type-badge type-lab">LAB</span>');
        if (period.isTutorial) badges.push('<span class="type-badge type-tut">TUT</span>');
        if (period.isElective) badges.push('<span class="type-badge type-elective">ELECTIVE</span>');
        return badges.join('');
      }

      function renderPeriods() {
        if (!activeDepartmentData) {
          dayPeriodList.innerHTML = '<div class="alert alert-warning">No timetable data available.</div>';
          return;
        }

        departmentGroupLabel.textContent = `${activeDepartmentData.department.label} • ${activeDepartmentData.groupName || 'Group Not Available'}`;
        const periods = activeDepartmentData.days && activeDepartmentData.days[activeDay] ? activeDepartmentData.days[activeDay] : [];

        if (!periods.length) {
          dayPeriodList.innerHTML = `<div class="alert alert-light border">No periods available for <strong>${activeDay}</strong>.</div>`;
          return;
        }

        dayPeriodList.innerHTML = periods.map((period) => {
          const entries = Array.isArray(period.entries) ? period.entries : [];
          const entryMarkup = entries.map((entry) => {
            const subjectName = entry.subject || (period.isFree ? 'Free Period' : 'Subject Not Available');
            const teacher = entry.teacher ? `<div class="small text-muted"><i class="fas fa-user me-1"></i>${entry.teacher}</div>` : '';
            const room = entry.classRoom ? `<div class="small text-muted"><i class="fas fa-location-dot me-1"></i>${entry.classRoom}</div>` : '';
            const electiveClass = period.isElective ? 'elective' : '';

            return `
              <div class="period-entry ${electiveClass}">
                <div class="fw-semibold">${subjectName}</div>
                ${teacher}
                ${room}
              </div>
            `;
          }).join('');

          return `
            <article class="period-card">
              <div class="d-flex flex-column flex-md-row gap-2">
                <div class="period-time">${period.time || '--:--'}</div>
                <div class="flex-grow-1">
                  <div>${displayTypeBadges(period)}</div>
                  ${entryMarkup}
                </div>
              </div>
            </article>
          `;
        }).join('');
      }

      function renderDayTabs() {
        const availableDays = dayOrder.filter((day) => activeDepartmentData && activeDepartmentData.days && Array.isArray(activeDepartmentData.days[day]) && activeDepartmentData.days[day].length > 0);
        if (!availableDays.includes(activeDay)) activeDay = availableDays[0] || 'Monday';

        dayTabs.innerHTML = availableDays.map((day) => `
          <button type="button" class="day-tab ${day === activeDay ? 'active' : ''}" data-day="${day}">
            ${day}
          </button>
        `).join('');

        dayTabs.querySelectorAll('.day-tab').forEach((button) => {
          button.addEventListener('click', function () {
            activeDay = this.dataset.day;
            renderDayTabs();
            renderPeriods();
          });
        });
      }

      async function loadTimetableForSelection() {
        if (!activeDepartmentKey || !activeGroupName) return;
        try {
          const response = await fetch(`/api/timetable/${activeDepartmentKey}/${encodeURIComponent(activeGroupName)}`);
          if (!response.ok) throw new Error('Failed to load timetable');
          activeDepartmentData = await response.json();
          renderDayTabs();
          renderPeriods();
        } catch (error) {
          activeDepartmentData = null;
          dayTabs.innerHTML = '';
          dayPeriodList.innerHTML = '<div class="alert alert-warning">Unable to load timetable for selected group.</div>';
        }
      }

      async function loadGroupsForDepartment() {
        if (!activeDepartmentKey) return;
        groupSelector.disabled = true;
        groupSelector.innerHTML = '<option value="">Loading groups...</option>';
        try {
          const response = await fetch(`/api/groups/${activeDepartmentKey}`);
          if (!response.ok) throw new Error('Failed to load groups');
          const payload = await response.json();
          const groups = Array.isArray(payload.groups) ? payload.groups : [];

          if (!groups.length) {
            groupSelector.innerHTML = '<option value="">No groups available</option>';
            dayTabs.innerHTML = '';
            dayPeriodList.innerHTML = '<div class="alert alert-light border">No groups found for this department.</div>';
            return;
          }

          groupSelector.innerHTML = groups.map((group) => `
            <option value="${group}">${group}</option>
          `).join('');
          groupSelector.disabled = false;
          const preferredGroup = currentUser && currentUser.group && groups.includes(currentUser.group)
            ? currentUser.group
            : groups[0];
          activeGroupName = preferredGroup;
          groupSelector.value = activeGroupName;
          await loadTimetableForSelection();
        } catch (error) {
          groupSelector.innerHTML = '<option value="">Unable to load groups</option>';
          dayTabs.innerHTML = '';
          dayPeriodList.innerHTML = '<div class="alert alert-warning">Unable to load groups right now.</div>';
        }
      }

      function renderDepartmentSwitcher() {
        if (userLockedTimetable) {
          departmentSwitcher.innerHTML = '';
          return;
        }
        departmentSwitcher.innerHTML = departmentOptions.map((department) => `
          <button type="button" class="department-chip ${department.key === activeDepartmentKey ? 'active' : ''}" data-department="${department.key}">
            ${department.label}
          </button>
        `).join('');

        departmentSwitcher.querySelectorAll('.department-chip').forEach((button) => {
          button.addEventListener('click', async function () {
            activeDepartmentKey = this.dataset.department;
            activeDepartmentData = null;
            renderDepartmentSwitcher();
            await loadGroupsForDepartment();
          });
        });
      }

      groupSelector.addEventListener('change', async function () {
        if (userLockedTimetable) return;
        activeGroupName = this.value;
        await loadTimetableForSelection();
      });

      async function bootTimetableSection() {
        if (!departmentOptions.length) {
          try {
            const response = await fetch('/api/departments');
            if (response.ok) {
              const payload = await response.json();
              departmentOptions = Array.isArray(payload.departments) ? payload.departments : [];
            }
          } catch (error) {
            // keep empty options on network failure
          }
        }

        if (departmentOptions.length > 0) {
          if (userLockedTimetable) {
            activeDepartmentKey = currentUser.department;
          } else {
            activeDepartmentKey = departmentOptions[0].key;
          }
          renderDepartmentSwitcher();
          await loadGroupsForDepartment();

          if (userLockedTimetable) {
            groupSelector.disabled = true;
          }
        } else {
          document.getElementById('timetableSection').innerHTML =
            '<div class="alert alert-warning mb-0">Timetable data is not available right now.</div>';
        }
      }

      bootTimetableSection();
    });
  </script>
</body>
</html>
