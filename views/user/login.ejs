<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Student Login | InfoCascade</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    body {
      background: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      border: none;
      border-radius: 18px;
      box-shadow: 0 8px 32px rgba(44, 62, 80, 0.15);
      overflow: hidden;
      transition: transform 0.3s;
      background: #fff;
    }
    .login-card:hover {
      transform: translateY(-4px) scale(1.01);
      box-shadow: 0 16px 40px rgba(44, 62, 80, 0.18);
    }
    .card-header {
      background: linear-gradient(135deg, #3498db, #2c3e50);
      color: white;
      text-align: center;
      padding: 2rem 1rem 1rem 1rem;
      border-bottom: none;
    }
    .card-body {
      padding: 2rem 2.5rem 2.5rem 2.5rem;
    }
    .form-label {
      font-weight: 600;
      color: #2c3e50;
    }
    .form-control {
      padding: 0.75rem 1rem;
      border-radius: 10px;
      border: 1.5px solid #dbeafe;
      font-size: 1rem;
      background: #f8fafc;
      transition: border-color 0.2s;
    }
    .form-control:focus {
      border-color: #3498db;
      box-shadow: 0 0 0 0.15rem rgba(52, 152, 219, 0.15);
    }
    .btn-primary {
      background: linear-gradient(90deg, #3498db, #2c3e50);
      border: none;
      font-weight: 600;
      letter-spacing: 0.5px;
      padding: 0.75rem;
      border-radius: 10px;
      font-size: 1.1rem;
      box-shadow: 0 2px 8px rgba(52, 152, 219, 0.08);
      transition: background 0.2s;
    }
    .btn-primary:hover {
      background: linear-gradient(90deg, #2c3e50, #3498db);
    }
    .login-icon {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      color: #fff;
      text-shadow: 0 2px 8px rgba(44,62,80,0.12);
    }
    .register-link {
      color: #3498db;
      font-weight: 500;
      text-decoration: none;
      transition: color 0.2s;
    }
    .register-link:hover {
      color: #2c3e50;
      text-decoration: underline;
    }
    .feedback {
      min-height: 24px;
      font-size: 1rem;
      margin-top: 0.5rem;
      text-align: center;
    }
    @media (max-width: 600px) {
      .card-body { padding: 1.2rem; }
    }
  </style>
</head>
<body>
  <main class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5">
      <div class="card login-card">
        <div class="card-header">
          <div class="login-icon"><i class="fas fa-user-graduate"></i></div>
          <h3 class="mb-0">Student Login</h3>
          <p class="mb-0" style="font-size:1rem;opacity:0.85;">Access your InfoCascade account</p>
        </div>
        <div class="card-body">
          <form id="loginForm" autocomplete="on">
            <input type="hidden" id="csrfToken" value="<%= csrfToken %>" />
            <div class="mb-3">
              <label for="email" class="form-label">Email (Gmail)</label>
              <input type="email" class="form-control" id="email" name="email" required autocomplete="username" maxlength="254" title="Use a valid Gmail address (@gmail.com)" />
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <div class="input-group">
                <input type="password" class="form-control" id="password" name="password" required autocomplete="current-password" />
                <button class="btn btn-outline-secondary" type="button" id="togglePassword" tabindex="-1" aria-label="Show password"><i class="fas fa-eye"></i></button>
              </div>
            </div>
            <button type="submit" class="btn btn-primary w-100" id="loginBtn">
              <span id="loginBtnText">Login</span>
              <span id="loginSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
          </form>
          <div id="loginError" class="feedback text-danger"></div>
          <div id="loginSuccess" class="feedback text-success"></div>
          <div class="mt-3 text-center">
            <a href="/register" class="register-link">Don't have an account? Register</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function isValidGmailAddress(email) {
      var t = email.trim();
      if (!t) return false;
      var lower = t.toLowerCase();
      if (!lower.endsWith('@gmail.com')) return false;
      if (t.indexOf(' ') !== -1) return false;
      var local = lower.slice(0, -10);
      if (!local.length) return false;
      return /^[a-zA-Z0-9._%+-]+$/.test(local);
    }

    document.addEventListener('DOMContentLoaded', function () {
      var pwd = document.getElementById('password');
      var toggle = document.getElementById('togglePassword');
      if (toggle && pwd) {
        toggle.addEventListener('click', function () {
          if (pwd.type === 'password') {
            pwd.type = 'text';
            toggle.innerHTML = '<i class="fas fa-eye-slash"></i>';
            toggle.setAttribute('aria-label', 'Hide password');
          } else {
            pwd.type = 'password';
            toggle.innerHTML = '<i class="fas fa-eye"></i>';
            toggle.setAttribute('aria-label', 'Show password');
          }
        });
      }
    });

    document.getElementById('loginForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var emailInput = document.getElementById('email').value.trim();
      var email = emailInput.toLowerCase();
      const password = document.getElementById('password').value;
      const errorDiv = document.getElementById('loginError');
      const successDiv = document.getElementById('loginSuccess');
      if (!isValidGmailAddress(emailInput)) {
        errorDiv.textContent = 'Enter a valid email address that ends with @gmail.com';
        return;
      }
      const btn = document.getElementById('loginBtn');
      const btnText = document.getElementById('loginBtnText');
      const spinner = document.getElementById('loginSpinner');
      errorDiv.textContent = '';
      successDiv.textContent = '';
      btn.disabled = true;
      btnText.textContent = 'Logging in...';
      spinner.classList.remove('d-none');
      try {
        const csrfToken = document.getElementById('csrfToken').value;
        const res = await fetch('/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'CSRF-Token': csrfToken
          },
          body: JSON.stringify({ email: email, password: password })
        });
        const data = await res.json();
        if (res.ok && data.success) {
          successDiv.textContent = 'Login successful! Redirecting...';
          setTimeout(() => { window.location.href = '/'; }, 800);
        } else {
          errorDiv.textContent = data.error || 'Login failed.';
        }
      } catch (err) {
        errorDiv.textContent = 'Network error.';
      }
      btn.disabled = false;
      btnText.textContent = 'Login';
      spinner.classList.add('d-none');
    });
  </script>
</body>
</html>
