<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Quick Links - InfoCascade</title>
  <link rel="icon" href="/images/Infocascade.png" type="image/png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    :root {
      --primary-color: #3498db;
      --secondary-color: #2c3e50;
      --accent-color: #e74c3c;
    }

    body {
      background-color: #f8f9fa;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .hero-header {
      background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
      color: white;
      border-radius: 10px;
      padding: 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      text-align: center;
    }

    .hero-header h1 {
      font-size: 2.5rem;
      font-weight: bold;
      margin-bottom: 0.5rem;
    }

    .links-container {
      padding: 2rem 0;
    }

    .category-section {
      margin-bottom: 3rem;
    }

    .category-title {
      color: var(--secondary-color);
      font-size: 1.8rem;
      font-weight: bold;
      border-bottom: 3px solid var(--primary-color);
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .link-card {
      background: white;
      border: 2px solid #e0e0e0;
      border-radius: 10px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .link-card:hover {
      border-color: var(--primary-color);
      box-shadow: 0 8px 20px rgba(52, 152, 219, 0.2);
      transform: translateY(-3px);
    }

    .link-icon {
      font-size: 2.5rem;
      color: var(--primary-color);
      min-width: 60px;
      text-align: center;
    }

    .link-content {
      flex: 1;
    }

    .link-title {
      font-size: 1.2rem;
      font-weight: bold;
      color: var(--secondary-color);
      margin-bottom: 0.5rem;
    }

    .link-description {
      color: #666;
      font-size: 0.95rem;
      margin-bottom: 0.8rem;
    }

    .link-button {
      display: inline-block;
      background: linear-gradient(135deg, var(--primary-color), #2980b9);
      color: white;
      padding: 0.6rem 1.2rem;
      border-radius: 5px;
      text-decoration: none;
      transition: all 0.3s ease;
      font-weight: bold;
      cursor: pointer;
      border: none;
    }

    .link-button:hover {
      transform: translateX(3px);
      box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
      text-decoration: none;
      color: white;
    }

    .back-button {
      margin-bottom: 2rem;
    }

    .back-button a {
      color: var(--primary-color);
      text-decoration: none;
      font-weight: bold;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .back-button a:hover {
      color: var(--secondary-color);
    }

    .no-links {
      text-align: center;
      padding: 2rem;
      color: #999;
      font-size: 1.1rem;
    }

    .navbar {
      background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .navbar-brand {
      font-weight: bold;
      font-size: 1.5rem;
    }

    .nav-link {
      transition: color 0.3s ease;
    }

    .nav-link:hover {
      color: var(--accent-color) !important;
    }
  </style>
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="fas fa-cascade"></i> InfoCascade
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/links" style="color: var(--accent-color);">Quick Links</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/profile">Profile</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Container -->
  <div class="container">
    <div class="back-button">
      <a href="/">
        <i class="fas fa-arrow-left"></i> Back to Home
      </a>
    </div>

    <!-- Hero Header -->
    <div class="hero-header">
      <h1>Quick Links</h1>
      <p>Access all important college resources in one place</p>
    </div>

    <!-- Links Container -->
    <div class="links-container">
      <% 
        const categories = ['College', 'Academics', 'Placement', 'Other'];
        let hasAnyLinks = false;
      %>

      <% categories.forEach(category => { 
        const linksInCategory = links.filter(link => link.category === category);
        if (linksInCategory.length > 0) {
          hasAnyLinks = true;
      %>
      <div class="category-section">
        <h2 class="category-title">
          <i class="fas fa-folder-open"></i>
          <%= category %>
        </h2>
        <div class="row">
          <% linksInCategory.forEach(link => { %>
          <div class="col-md-6">
            <div class="link-card">
              <div class="link-icon">
                <i class="fas <%= link.icon %>"></i>
              </div>
              <div class="link-content">
                <div class="link-title"><%= link.title %></div>
                <% if (link.description) { %>
                <div class="link-description"><%= link.description %></div>
                <% } %>
                <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" class="link-button">
                  Visit <i class="fas fa-external-link-alt"></i>
                </a>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>
      <% }); %>

      <% if (!hasAnyLinks) { %>
      <div class="no-links">
        <i class="fas fa-link fa-3x mb-3"></i>
        <p>No links available at the moment.</p>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white text-center py-3 mt-5">
    <p>&copy; 2024 InfoCascade. All rights reserved.</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
