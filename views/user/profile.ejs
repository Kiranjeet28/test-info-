<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Profile | InfoCascade</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <style>
    @media (max-width: 576px) {
      .profile-actions .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/">InfoCascade</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNavbar">
        <div class="navbar-nav ms-auto text-center">
          <a class="nav-link" href="/">Home</a>
          <a class="nav-link" href="/timetable">Timetable</a>
          <a class="nav-link active" href="/profile">Profile</a>
        </div>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-primary text-white">
            <h4 class="mb-0">My Profile</h4>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-6"><strong>Name:</strong> <%= currentUser.name || '-' %></div>
              <div class="col-md-6"><strong>Email:</strong> <%= currentUser.email || '-' %></div>
              <div class="col-md-6"><strong>URN:</strong> <%= currentUser.urn || '-' %></div>
              <div class="col-md-6"><strong>CRN:</strong> <%= currentUser.crn || '-' %></div>
              <div class="col-md-6"><strong>Department:</strong> <%= currentUser.department || '-' %></div>
              <div class="col-md-6"><strong>Group:</strong> <%= currentUser.group || '-' %></div>
            </div>
            <div class="profile-actions mt-4">
              <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
